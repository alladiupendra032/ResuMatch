# MongoDB
# Local development — change to Atlas URL in Render dashboard for production
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=resumatch

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-to-a-random-256-bit-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
